# Supabase — kopieer dit bestand naar .env.local en vul je eigen keys in
# Maak een project aan op https://supabase.com, ga naar Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key-hier

# App URL (voor auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
